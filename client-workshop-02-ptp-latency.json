{
  "workshop": {
    "schema": {
      "version": "2020.03.02"
    }
  },
  "userenvs": [
    {
      "name": "alma9",
      "requirements": [
        "pip",
        "ptp-latency-src",
        "ptp-latency-build"
      ]
    }
  ],
  "requirements": [
    {
      "name": "pip",
      "type": "python3",
      "python3_info": {
         "packages": [
           "posix_ipc"
         ]
       }
    },
    {
      "name": "ptp-latency-src",
      "type": "files",
      "files_info": {
        "files": [
          {
            "src": "%bench-dir%/trafficgen/ptp-latency.c",
            "dst": "/tmp/build/"
          },
          {
            "src": "%bench-dir%/trafficgen/build-ptp-latency.sh",
            "dst": "/usr/bin"
          }
        ]
      }
    },
    {
      "name": "ptp-latency-build",
      "type": "manual",
      "manual_info": {
        "commands": [
          "/usr/bin/build-ptp-latency.sh /tmp/build/ptp-latency.c /usr/bin/ptp-latency && rm -rf /tmp/build"
        ]
      }
    }
  ]
}
