{
  "workshop": {
    "schema": {
      "version": "2020.03.02"
    }
  },
  "userenvs": [
    {
      "name": "default",
      "requirements": [
        "trafficgen-server-os-dependencies"
      ]
    },
    {
      "name": "alma8",
      "requirements": [
        "trafficgen-server-os-dependencies",
        "set-python3.12"
      ]
    }
  ],
  "requirements": [
    {
      "name": "trafficgen-server-os-dependencies",
      "type": "distro",
      "distro_info": {
        "packages": [
          "rdma-core-devel",
          "dpdk-tools",
          "net-tools",
          "which",
          "bc"
        ]
      }
    },
    {
      "name": "set-python3.12",
      "type": "manual",
      "manual_info": {
        "commands": [
          "alternatives --set python3 /usr/bin/python3.12"
        ]
      }
    }
  ]
}
