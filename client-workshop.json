{
  "workshop": {
    "schema": {
      "version": "2020.03.02"
    }
  },
  "userenvs": [
    {
      "name": "alma9",
      "requirements": [
        "dev-tools",
        "trafficgen-client-os-dependencies",
        "pip",
        "trex1",
        "trex2",
        "ptp-latency-src",
        "ptp-latency-build"
      ]
    },
    {
      "name": "alma10",
      "requirements": [
        "dev-tools",
        "trafficgen-client-os-dependencies",
        "pip",
        "trex1",
        "trex2"
      ]
    }
  ],
  "requirements": [
    {
      "name": "dev-tools",
      "type": "distro",
      "distro_info": {
        "groups": [
          "\"Development Tools\""
        ]
      }
    },
    {
      "name": "trafficgen-client-os-dependencies",
      "type": "distro",
      "distro_info": {
        "packages": [
          "rdma-core-devel",
          "dpdk-tools",
          "net-tools",
          "which",
          "bc",
          "python3-devel",
          "numactl-devel",
          "cmake",
          "libarchive"
        ]
      }
    },
    {
      "name": "pip",
      "type": "python3",
      "python3_info": {
         "packages": [
           "pyyaml",
           "jsonschema",
           "redis",
           "hiredis",
           "posix_ipc"
         ]
       }
    },
    {
      "name": "trex1",
      "type": "files",
      "files_info": {
        "files": [
          {
            "src": "%bench-dir%/trafficgen/install-trex.sh",
            "dst": "/usr/bin"
          }
        ]
      }
    },
    {
      "name": "trex2",
      "type": "manual",
      "manual_info": {
        "commands": [
          "/usr/bin/install-trex.sh --insecure"
        ]
      }
    },
    {
      "name": "ptp-latency-src",
      "type": "files",
      "files_info": {
        "files": [
          {
            "src": "%bench-dir%/trafficgen/ptp-latency.c",
            "dst": "/tmp/build/"
          },
          {
            "src": "%bench-dir%/trafficgen/build-ptp-latency.sh",
            "dst": "/usr/bin"
          }
        ]
      }
    },
    {
      "name": "ptp-latency-build",
      "type": "manual",
      "manual_info": {
        "commands": [
          "/usr/bin/build-ptp-latency.sh /tmp/build/ptp-latency.c /usr/bin/ptp-latency && rm -rf /tmp/build"
        ]
      }
    }
  ]
}
